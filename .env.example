# ────────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ────────────────────────────────────────────────────────────────
# Local: docker run -p 5432:5432 -e POSTGRES_PASSWORD=prism postgres:16
# Or sign up for a free Neon / Supabase / Vercel Postgres branch.
DATABASE_URL="postgresql://postgres:prism@localhost:5432/prism"

# ────────────────────────────────────────────────────────────────
# NextAuth
# ────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-me-with-32-bytes-of-randomness"
# Leave AUTH_URL unset on Vercel — AUTH_TRUST_HOST=true uses the deploy URL.
# In dev (or other hosts): set explicitly.
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Used to encrypt platform OAuth tokens at rest. Generate: openssl rand -hex 32
PRISM_TOKEN_KEY="replace-me-with-64-hex-characters"

# ────────────────────────────────────────────────────────────────
# OAuth providers (optional — leave blank to disable that provider)
# ────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email magic-link (SMTP). Leave EMAIL_SERVER blank to disable.
EMAIL_SERVER=""
EMAIL_FROM="Prism <hello@prism.app>"

# ────────────────────────────────────────────────────────────────
# TikTok for Developers — Login Kit + Display API
# https://developers.tiktok.com/
# See CONNECTIONS.md for the full setup walkthrough.
# ────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
# Must exactly match a redirect URI registered with your TikTok app
TIKTOK_REDIRECT_URI="http://localhost:3000/api/connect/tiktok/callback"

# ────────────────────────────────────────────────────────────────
# Meta (Instagram) — Graph API via Instagram Login
# https://developers.facebook.com/docs/instagram-platform
# See CONNECTIONS.md for the full setup walkthrough.
# ────────────────────────────────────────────────────────────────
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI="http://localhost:3000/api/connect/instagram/callback"
